{
  "expo": {
    "name": "bondiz-app",
    "slug": "bondiz-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo_purple.png",
    "scheme": "bondizapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bondiz.bondizapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo_purple.png",
        "backgroundImage": "./assets/images/logo_purple.png",
        "monochromeImage": "./assets/images/logo_purple.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.bondiz.bondizapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo_purple.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo_purple.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "L'application accède à vos photos pour vous permettre de les partager avec vos amis."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}